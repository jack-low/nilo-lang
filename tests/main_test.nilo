from "../examples/math_tools" import add, sum_to;
import "std/json" as json;
import "std/regex" as regex;

let values = [1, 2, 3];
let total = 0;

for value in values {
    total = total + value;
}

if (add(total, 4) != 10) {
    print("add failed");
}

if (sum_to(5) != 15) {
    print("sum_to failed");
}

let data = json.parse("{\"name\":\"nilo\"}");
print(data.name);

if (!regex.is_match("^[a-z]+$", "nilo")) {
    print("regex is_match failed");
}

let email = regex.captures("(?P<user>[\\w.]+)@(?P<host>[\\w.]+)", "dev@example.com");
if (email.named.user != "dev") {
    print("regex named capture failed");
}

let words = regex.find_all("\\w+", "Nilo speaks many languages");
if (len(words) != 4) {
    print("regex find_all failed");
}

let normalized = regex.replace("\\s+", "Nilo Language", "-");
if (normalized != "Nilo-Language") {
    print("regex replace failed");
}
